{
  "name": "zyrehub",
  "displayName": "ZyreHub",
  "description": "The ultimate developer assistant: Smart Git, QoL tools, and minimalist design.",
  "version": "1.1.1",
  "publisher": "snow-099",
  "icon": "Assets/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/SnoW-099/zyrehub.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "keywords": [
    "git",
    "automation",
    "theme",
    "dashboard",
    "developer"
  ],
  "categories": [
    "Themes",
    "Other",
    "Programming Languages"
  ],
  "activationEvents": [
    "onCommand:zyrehub.sync",
    "onCommand:zyrehub.validate",
    "onCommand:zyrehub.readmeWizard",
    "onCommand:zyrehub.fastFix",
    "onCommand:zyrehub.openDashboard",
    "onCommand:zyrehub.shareGist",
    "onView:zyrehubQuickActions",
    "onView:zyrehubProjectHealth",
    "onView:zyrehubTodoExplorer"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "themes": [
      {
        "label": "ZyreHub Night Sky",
        "uiTheme": "vs-dark",
        "path": "./themes/zyrehub-color-theme.json"
      }
    ],
    "walkthroughs": [
      {
        "id": "zyrehub-getting-started",
        "title": "Welcome to ZyreHub Pro!",
        "description": "Learn how to automate your workflow in seconds.",
        "steps": [
          {
            "id": "setup",
            "title": "Initial Setup",
            "description": "Configure your GitHub token to unlock all Pro features. [Configure Settings](command:workbench.action.openSettings?%22zyrehub.githubToken%22)",
            "media": {
              "svg": "Assets/logo.png",
              "altText": "ZyreHub Logo"
            }
          },
          {
            "id": "first-sync",
            "title": "Smart Sync",
            "description": "Try your first automated commit and push. ZyreHub will handle everything. [Run Sync](command:zyrehub.sync)",
            "media": {
              "svg": "Assets/logo.png",
              "altText": "ZyreHub Logo"
            }
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "zyrehub-explorer",
          "title": "ZyreHub",
          "icon": "$(rocket)"
        }
      ]
    },
    "views": {
      "zyrehub-explorer": [
        {
          "id": "zyrehubQuickActions",
          "name": "Quick Actions",
          "icon": "$(zap)"
        },
        {
          "id": "zyrehubProjectHealth",
          "name": "Project Health",
          "icon": "$(heart)"
        },
        {
          "id": "zyrehubTodoExplorer",
          "name": "TODO Explorer",
          "icon": "$(checklist)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "zyrehubQuickActions",
        "contents": "Open a folder to unlock ZyreHub tools.\n[Open Folder](command:vscode.openFolder)",
        "when": "workbenchState == empty"
      },
      {
        "view": "zyrehubProjectHealth",
        "contents": "Open a folder to see project health.\n[Open Folder](command:vscode.openFolder)",
        "when": "workbenchState == empty"
      },
      {
        "view": "zyrehubTodoExplorer",
        "contents": "Open a folder to scan for TODOs.\n[Open Folder](command:vscode.openFolder)",
        "when": "workbenchState == empty"
      }
    ],
    "commands": [
      {
        "command": "zyrehub.showWelcome",
        "title": "ZyreHub: Show Welcome Screen",
        "category": "ZyreHub"
      },
      {
        "command": "zyrehub.openDashboard",
        "title": "ZyreHub: Open Pro Dashboard",
        "category": "ZyreHub"
      },
      {
        "command": "zyrehub.shareGist",
        "title": "ZyreHub: Share selection as Gist",
        "category": "ZyreHub"
      },
      {
        "command": "zyrehub.sync",
        "title": "ZyreHub: Sync Repository",
        "category": "ZyreHub"
      },
      {
        "command": "zyrehub.validate",
        "title": "ZyreHub: Project Health Check",
        "category": "ZyreHub"
      },
      {
        "command": "zyrehub.securityCheck",
        "title": "ZyreHub: Run Security Audit",
        "category": "ZyreHub"
      },
      {
        "command": "zyrehub.readmeWizard",
        "title": "ZyreHub: README Wizard",
        "category": "ZyreHub"
      },
      {
        "command": "zyrehub.fastFix",
        "title": "ZyreHub: Fast Fix (Format & Clean)",
        "category": "ZyreHub"
      },
      {
        "command": "zyrehub.refreshHealth",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "zyrehub.refreshTodos",
        "title": "Refresh",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "zyrehub.refreshHealth",
          "when": "view == zyrehubProjectHealth",
          "group": "navigation"
        },
        {
          "command": "zyrehub.refreshTodos",
          "when": "view == zyrehubTodoExplorer",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "ZyreHub",
      "properties": {
        "zyrehub.githubToken": {
          "type": "string",
          "default": "",
          "description": "GitHub Personal Access Token for remote repository management.",
          "scope": "application"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.1.3",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "eslint": "^8.41.0",
    "@vscode/vsce": "^2.19.0"
  },
  "dependencies": {
    "octokit": "^2.0.14",
    "simple-git": "^3.16.0"
  }
}
