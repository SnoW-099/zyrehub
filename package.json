{
  "name": "zyrehub",
  "displayName": "ZyreHub",
  "description": "Quality of Life features and a minimal dark theme for developers",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "themes": [
      {
        "label": "ZyreHub Night Sky",
        "uiTheme": "vs-dark",
        "path": "./themes/zyrehub-color-theme.json"
      }
    ],
    "commands": [
      {
        "command": "zyrehub.fastFix",
        "title": "ZyreHub: Fast Fix (Format & Clean)"
      },
      {
        "command": "zyrehub.quickCommit",
        "title": "ZyreHub: Quick Commit"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.1.3",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "eslint": "^8.41.0"
  }
}
